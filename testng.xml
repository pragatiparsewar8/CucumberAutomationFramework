<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Cucumber Suite" parallel="tests" thread-count="4">
  
  <!-- Register RetryListener globally -->
  <listeners>
    <listener class-name="com.framework.listeners.RetryListener"/>
    <listener class-name="com.framework.listeners.TestListeners"/>
</listeners>


  <test name="Cucumber Tests">
    <classes>
      <!-- Your main runner -->
      <class name="runners.TestRunner"/>
    </classes>
  </test>

 

</suite>
